# ── 하실장 비서실 웹 앱 환경변수 ───────────────────────────────
# 이 파일을 복사해서 .env.local 을 만들고 값을 채우세요.
#   cp .env.example .env.local

# Anthropic API 키 (필수). https://console.anthropic.com 에서 발급.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 답변 생성 모델 (선택). 비우면 기본값 사용.
ANSWER_MODEL=claude-opus-4-8

# 라우팅(에이전트 자동배정) 모델 (선택). 빠르고 저렴한 모델 권장.
ROUTER_MODEL=claude-haiku-4-5-20251001

# 접속 비밀번호 (선택, 강력 권장). 설정하면 앱 진입 시 이 값을 요구합니다.
# 회장님 외 접근을 막는 1차 잠금장치입니다.
APP_PASSWORD=

# ── 일일 인텔리전스 리포트 ───────────────────────────────
# 웹 검색 API 키 (Tavily 권장). https://tavily.com 에서 발급.
# 이 키가 있어야 매일 자동 검색/리포트가 동작합니다.
TAVILY_API_KEY=
# (대안) 동일 용도의 검색 키를 SEARCH_API_KEY 로 넣어도 됩니다.
SEARCH_API_KEY=

# 예약함수(매일 07:00 KST)가 리포트 생성 API를 호출할 때 쓰는 비밀 토큰.
# 아무 임의 문자열로 설정하세요(외부 무단 트리거 방지).
CRON_SECRET=

# 리포트 시간대/시각 (참고용 — 실제 스케줄은 netlify 예약함수 cron으로 동작)
REPORT_TIMEZONE=Asia/Seoul
DAILY_REPORT_HOUR=7
